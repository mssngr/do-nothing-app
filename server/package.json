{
  "name": "do-nothing-app-api",
  "license": "UNLICENSED",
  "dependencies": {
    "cors": "^2.8.5",
    "jsonwebtoken": "^8.5.1",
    "nexus": "0.20.0",
    "nexus-plugin-jwt-auth": "^1.0.0",
    "nexus-plugin-prisma": "^0.7.0",
    "ramda": "^0.27.0"
  },
  "scripts": {
    "build": "nexus build",
    "dev": "nexus dev",
    "format": "npx prettier --write './**/*.{ts,md}'",
    "generate": "yarn -s prisma generate",
    "migrate": "yarn migrate-save && yarn migrate-up",
    "migrate-save": "yarn -s prisma migrate save --experimental",
    "migrate-up": "yarn -s prisma migrate up --experimental",
    "start": "node node_modules/.build"
  },
  "devDependencies": {
    "@types/cors": "^2.8.6",
    "@types/jsonwebtoken": "^8.3.9",
    "@types/ramda": "^0.27.4",
    "prettier": "^2.0.5"
  }
}
