{
  "name": "do-nothing-app-server",
  "license": "UNLICENSED",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nexus build",
    "dev": "nexus dev",
    "format": "prettier --write './**/*.{js,ts,md,json}'",
    "generate": "yarn -s prisma generate",
    "lint": "eslint './src/**/*.{js,ts}'",
    "migrate": "yarn migrate-save && yarn migrate-up",
    "migrate-save": "yarn -s prisma migrate save --experimental",
    "migrate-up": "yarn -s prisma migrate up --experimental",
    "start": "node node_modules/.build"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "bcrypt": "^4.0.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.0.0",
    "jsonwebtoken": "^9.0.0",
    "nexus": "0.20.0",
    "nexus-plugin-jwt-auth": "^1.0.0",
    "nexus-plugin-prisma": "^0.7.0",
    "ramda": "^0.27.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^3.0.0",
    "@types/cors": "^2.8.6",
    "@types/crypto-js": "^3.1.46",
    "@types/jsonwebtoken": "^8.3.9",
    "@types/ramda": "^0.27.4",
    "@typescript-eslint/eslint-plugin": "^2.34.0",
    "@typescript-eslint/parser": "^2.34.0",
    "eslint": "^7.0.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.3",
    "husky": "^4.2.5",
    "lint-staged": "^10.2.4",
    "prettier": "^2.0.5"
  }
}
